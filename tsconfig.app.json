{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"noEmit": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},

	"include": ["src", "vite.config.ts"]
}
